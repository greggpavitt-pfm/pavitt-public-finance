# =============================================================================
# Pavitt Public Finance — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local — it is git-ignored by default.
# =============================================================================

# ---------------------------------------------------------------------------
# SUPABASE
# ---------------------------------------------------------------------------
# Found in your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# AI / LLM CONFIGURATION
# ---------------------------------------------------------------------------
# Provider: anthropic | openai | google
# Change this single var to switch providers — no code changes needed.
AI_PROVIDER=anthropic

# Model ID: the specific model to use for the chosen provider
# Examples:
#   anthropic → claude-sonnet-4-6, claude-haiku-4-5-20251001
#   openai    → gpt-4o, gpt-4o-mini
#   google    → gemini-2.0-flash, gemini-2.5-pro
AI_MODEL=claude-sonnet-4-6

# API key for the chosen provider
AI_API_KEY=your-api-key-here

# ---------------------------------------------------------------------------
# CONTACT FORM (Phase 4)
# ---------------------------------------------------------------------------
CONTACT_EMAIL=gregg@pfmexpert.net
